run = "npm run dev"
modules = ["nodejs-20", "postgresql-16", "python-3.11"]
hidden = [".config", "tsconfig.json", "tsconfig.node.json", "vite.config.js", ".gitignore"]
entrypoint = "src/App.tsx"

[nix]
channel = "stable-24_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libxcrypt", "pkg-config", "qhull", "tcl", "tk", "xsimd"]

[unitTest]
language = "nodejs"

[deployment]
deploymentTarget = "vm"
build = ["npm", "install"]
publicDir = "dist"
run = ["npm", "run", "dev:all"]

[[deployment.rewrites]]
from = "/*"
to = "/index.html"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[[ports]]
localPort = 5002
externalPort = 5173

[[ports]]
localPort = 40603
externalPort = 5000

[[ports]]
localPort = 41947
externalPort = 3002

[[ports]]
localPort = 43593
externalPort = 6800

[[ports]]
localPort = 44189
externalPort = 8000

[[ports]]
localPort = 44565
externalPort = 3000

[[ports]]
localPort = 45687
externalPort = 3003

[[ports]]
localPort = 46503
externalPort = 6000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Development Server"
author = 46760603
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Rider App Server"
author = 46760603
mode = "sequential"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App Server"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"The rider app is integrated into the main React app. Navigate to /rider route to see the maps.\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"Main app is running on the Development Server workflow.\""

[[workflows.workflow]]
name = "Main App"
author = 46760603
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
