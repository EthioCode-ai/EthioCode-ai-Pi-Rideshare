author = 46760603
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Full Stack Dev"
author = 46760603
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && npm install && node index.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
